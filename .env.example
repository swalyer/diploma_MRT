# Shared
APP_JWT_SECRET=replace-with-long-random-secret-at-least-32-bytes
APP_ML_MODE=mock
ML_MODE=mock

# Deployment mode notes:
# - For single-host/shared Docker network, DB hostnames may be Docker service names.
# - For multi-host deployment, use real DNS names or private IPs reachable between hosts.

# Public edge URL + frontend/backend API routing
APP_PUBLIC_BASE_URL=https://your-edge-host
VITE_API_BASE_URL=/api

# Primary DB
APP_DB_PRIMARY_HOST=postgres-primary
APP_DB_PRIMARY_PORT=5432
APP_DB_PRIMARY_NAME=mrt
APP_DB_PRIMARY_USERNAME=mrt
APP_DB_PRIMARY_PASSWORD=mrt
SPRING_DATASOURCE_URL=jdbc:postgresql://${APP_DB_PRIMARY_HOST}:${APP_DB_PRIMARY_PORT}/${APP_DB_PRIMARY_NAME}
SPRING_DATASOURCE_USERNAME=${APP_DB_PRIMARY_USERNAME}
SPRING_DATASOURCE_PASSWORD=${APP_DB_PRIMARY_PASSWORD}

# Read replica DB
APP_DB_REPLICA_HOST=postgres-replica
APP_DB_REPLICA_PORT=5432
APP_DB_REPLICA_NAME=mrt
APP_DB_REPLICA_USERNAME=mrt
APP_DB_REPLICA_PASSWORD=mrt
APP_READ_REPLICA_ENABLED=true
APP_READ_DATASOURCE_URL=jdbc:postgresql://${APP_DB_REPLICA_HOST}:${APP_DB_REPLICA_PORT}/${APP_DB_REPLICA_NAME}
APP_READ_DATASOURCE_USERNAME=${APP_DB_REPLICA_USERNAME}
APP_READ_DATASOURCE_PASSWORD=${APP_DB_REPLICA_PASSWORD}

# Audit DB
APP_AUDIT_ENABLED=true
APP_AUDIT_DB_HOST=audit-postgres
APP_AUDIT_DB_PORT=5432
APP_AUDIT_DB_NAME=mrt_audit
APP_AUDIT_DB_USERNAME=mrt_audit
APP_AUDIT_DB_PASSWORD=mrt_audit
APP_AUDIT_DATASOURCE_URL=jdbc:postgresql://${APP_AUDIT_DB_HOST}:${APP_AUDIT_DB_PORT}/${APP_AUDIT_DB_NAME}
APP_AUDIT_DATASOURCE_USERNAME=${APP_AUDIT_DB_USERNAME}
APP_AUDIT_DATASOURCE_PASSWORD=${APP_AUDIT_DB_PASSWORD}

# Storage (MinIO)
APP_STORAGE_ENDPOINT=http://minio:9000
APP_STORAGE_ACCESS_KEY=minio
APP_STORAGE_SECRET_KEY=minio123
APP_STORAGE_BUCKET=mrt-artifacts
APP_STORAGE_ROOT=./storage

# Observability
APP_OBSERVABILITY_ENABLED=true
APP_LOG_LEVEL=INFO
